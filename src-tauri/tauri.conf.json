{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Messaging Console",
  "version": "0.1.0",
  "identifier": "us.future1.hermes.messaging",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:38998",
    "beforeBuildCommand": "npm run web:build:tauri",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hermes Messaging Console",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "capabilities": ["main"],
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://whats.future1.us; img-src 'self' data: blob: https://whats.future1.us; media-src 'self' blob: https://whats.future1.us; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
